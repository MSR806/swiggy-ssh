# ── application ──────────────────────────────────────────────────────────────

# Environment name. Set to "production" to enable prod safeguards
# (refuses to start with the default TOKEN_ENCRYPTION_KEY).
APP_ENV=local

# Swiggy provider to use: "mock" for local dev/tests, "swiggy" for real API.
SWIGGY_PROVIDER=mock

# ── SSH server ────────────────────────────────────────────────────────────────

# Address the SSH server listens on.
SSH_ADDR=:2222

# Path to the persistent Ed25519 host key. Created automatically on first run.
# Mount this path as a Docker volume so the key survives container restarts —
# changing it will cause "Host key verification failed" for existing clients.
SSH_HOST_KEY_PATH=.local/ssh_host_ed25519_key

# ── HTTP server ───────────────────────────────────────────────────────────────

# Address the HTTP server listens on (browser login page + /health).
HTTP_ADDR=:8080

# Base URL shown to SSH users in the browser login prompt.
# Update this if you change HTTP_ADDR or expose the service publicly.
PUBLIC_BASE_URL=http://localhost:8080

# ── Postgres ──────────────────────────────────────────────────────────────────

# Host port mapped to the Compose Postgres container.
POSTGRES_PORT=5432

# Full Postgres connection string used by the app and migrations.
DATABASE_URL=postgres://swiggy:swiggy@localhost:5432/swiggy_ssh?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────

# Host port mapped to the Compose Redis container.
REDIS_PORT=6379

# Full Redis connection string used by the login-code service.
REDIS_URL=redis://localhost:6379/0

# ── auth ──────────────────────────────────────────────────────────────────────

# How long a browser login code stays valid before expiring.
LOGIN_CODE_TTL=10m

# AES-256-GCM token encryption key — base64url-encoded 32 bytes.
# The value below is the LOCAL DEV DEFAULT and is publicly known.
# It must never be used in production — the server refuses to start with it
# when APP_ENV=production.
#
# Generate a production key:
#   openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
TOKEN_ENCRYPTION_KEY=c3dpZ2d5LXNzaC1sb2NhbC1kZXYta2V5LTMyYnl0ZXM
